# ============================================================
# Orion CMS + public site — copy to .env and fill in.
# ============================================================

# Shared Postgres (SAME database the chat service uses).
# Note: Payload uses postgres://  (the chat service uses postgresql+psycopg://)
DATABASE_URI=postgresql://orion:orion@db:5432/orion

# Long random string — signs admin sessions. Change this!
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Where the CMS pushes knowledge docs so the AI can answer from them.
CHAT_INGEST_URL=http://chat:8000/ingest

# Browser -> chat service endpoint used by the public chat widget.
# Must be reachable FROM THE BROWSER (so a public URL in prod, not "chat:8000").
NEXT_PUBLIC_CHAT_ENDPOINT=http://localhost:8000/chat
