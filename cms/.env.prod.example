# Copy to cms/.env.prod for the production stack. Fill in the real domain.

# Shared Postgres (the "db" container). Must match db.env credentials.
DATABASE_URI=postgresql://orion:change-me-to-a-strong-password@db:5432/orion

# Long random string — signs admin sessions. CHANGE THIS.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# First admin account, created automatically on first boot. CHANGE BOTH —
# these are your login. (You can change the password later in the admin.)
SEED_ADMIN_EMAIL=you@yourdomain.com
SEED_ADMIN_PASSWORD=change-me-to-a-strong-password

# Chat ingest — server-to-server, inside the Docker network.
CHAT_INGEST_URL=http://chat:8000/ingest

# Public URLs. Same-origin via Caddy: the site is the domain, the chat is under
# /chat-api. The browser widget calls NEXT_PUBLIC_CHAT_ENDPOINT.
#   VPS:   https://orionilam.com  +  https://orionilam.com/chat-api/chat
#   Local: http://localhost       +  http://localhost/chat-api/chat
NEXT_PUBLIC_SERVER_URL=https://orionilam.com
NEXT_PUBLIC_CHAT_ENDPOINT=https://orionilam.com/chat-api/chat
