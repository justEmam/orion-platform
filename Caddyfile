# Caddy reverse proxy — the single entry point for the whole app.
#
# Caddy automatically fetches + renews a free HTTPS certificate for your domain
# (via Let's Encrypt) and routes traffic:
#   yourdomain.com/chat-api/*  -> the chat service (path stripped)
#   yourdomain.com/*           -> the site + admin (Payload/Next.js)
#   www.yourdomain.com         -> redirect to yourdomain.com
#
# Everything is same-origin (one domain), so there are no CORS problems.
#
# Env vars (set in caddy.env):
#   SITE_DOMAIN  — on the VPS: yourdomain.com   | locally: http://localhost
#   WWW_DOMAIN   — on the VPS: www.yourdomain.com (needs its own DNS record!)
#                  locally: leave unset (harmless default below)

{$SITE_DOMAIN} {
	# Chat API — strip the /chat-api prefix, forward the rest to the chat service.
	handle_path /chat-api/* {
		reverse_proxy chat:8000
	}

	# Everything else -> the CMS + public site.
	handle {
		# SECURITY: creating escalation records is reserved for the internal
		# chat service (which posts directly to cms:3001, bypassing Caddy).
		# Block public POSTs so bots can't spam the Escalations panel.
		# GET/PATCH/DELETE stay open — the admin UI needs them (list / mark
		# handled), and Payload's own auth protects those.
		@escalationsCreate {
			path /api/escalations /api/escalations/*
			method POST
		}
		respond @escalationsCreate "Not found" 404

		reverse_proxy cms:3001
	}
}

# www -> apex redirect. ONLY active if you set WWW_DOMAIN in caddy.env (i.e.
# once you have a domain + a "www" DNS A record). If WWW_DOMAIN is unset — e.g.
# running on a bare IP with no domain yet — this block binds to a private,
# non-routable host and is effectively inert (nothing reaches it).
#
# The redirect target MUST include the https:// scheme. SITE_DOMAIN is a bare
# host (e.g. orionilam.com) so Caddy can issue its cert — but a scheme-less
# `redir` produces a RELATIVE redirect, which loops (…/orionilam.com/orionilam
# .com/…). Set WWW_REDIRECT_TO=https://orionilam.com in caddy.env to be safe.
{$WWW_DOMAIN:http://www.invalid} {
	redir {$WWW_REDIRECT_TO:https://orionilam.com}{uri} permanent
}
