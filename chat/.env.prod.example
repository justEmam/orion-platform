# Copy to chat/.env.prod for the production stack.

# --- OpenAI powers BOTH the chat replies AND the embeddings (one key). ---
CHAT_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini              # cheap + capable for a support chat

EMBEDDINGS_PROVIDER=openai
# (uses the same OPENAI_API_KEY above; model is text-embedding-3-small)

# Shared Postgres (the "db" container). Must match db.env.
# The app auto-normalizes postgres:// -> postgresql+psycopg://.
DATABASE_URL=postgresql://orion:change-me-to-a-strong-password@db:5432/orion

# Human handoff (optional — leave blank to just log escalations).
SUPPORT_EMAIL=hello@orionilam.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=

# Lock the chat API to your real site origin (the domain, no path).
#   VPS:   https://orionilam.com
#   Local: http://localhost
ALLOWED_ORIGINS=https://orionilam.com
RATE_LIMIT=20/minute
