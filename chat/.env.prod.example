# Copy to chat/.env.prod for the production stack.

# --- Which model powers chat replies. SWITCHING PROVIDER = change these 2-3
#     lines only (the code is provider-agnostic). Pick ONE: ---
#
#   openai    (production default)   CHAT_PROVIDER=openai  + OPENAI_API_KEY + OPENAI_MODEL=gpt-4o-mini
#   anthropic (Claude)               CHAT_PROVIDER=anthropic + ANTHROPIC_API_KEY + ANTHROPIC_MODEL=claude-haiku-4-5-20251001
#   groq      (FREE — for testing)   CHAT_PROVIDER=groq + GROQ_API_KEY + GROQ_MODEL=llama-3.3-70b-versatile
#
# Testing now with free Groq; flip to the customer's OpenAI/Anthropic key later.
CHAT_PROVIDER=groq
GROQ_API_KEY=your-free-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# (No embeddings — the chat prompt-stuffs the FAQ, so no embedding key needed.)

# Shared Postgres (the "db" container). Must match db.env.
# The app auto-normalizes postgres:// -> postgresql+psycopg://.
DATABASE_URL=postgresql://orion:change-me-to-a-strong-password@db:5432/orion

# Escalations are SAVED TO THE CMS (shown in the admin), not emailed.
# Server-to-server inside the Docker network:
CMS_ESCALATION_URL=http://cms:3001/api/escalations

# Lock the chat API to your real site origin (the domain, no path).
#   VPS:   https://orionilam.com
#   Local: http://localhost
ALLOWED_ORIGINS=https://orionilam.com
RATE_LIMIT=20/minute
