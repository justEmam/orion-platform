# ============================================================
# Orion chat service — copy to .env and fill in.
# Only the ACTIVE provider's key is required.
# ============================================================

# --- Which LLM answers chats: anthropic | groq | openai ---
CHAT_PROVIDER=anthropic

# Claude (production default)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Groq (free tier for testing — set CHAT_PROVIDER=groq to use)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings: hf (free hosted, default) | openai | local (offline, ~2GB) ---
EMBEDDINGS_PROVIDER=hf
# Free HF token (no card): https://huggingface.co/settings/tokens
HF_API_KEY=
# For EMBEDDINGS_PROVIDER=openai instead:
# OPENAI_API_KEY is set above; embeddings cost ~$0.02 / 1M tokens (pennies).

# --- Shared Postgres (same DB as the CMS; pgvector lives here) ---
DATABASE_URL=postgresql+psycopg://orion:orion@db:5432/orion

# --- Human handoff ---
SUPPORT_EMAIL=hello@orionilam.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=

# --- Security ---
ALLOWED_ORIGINS=http://localhost:3000,https://www.orionilam.com
RATE_LIMIT=20/minute
