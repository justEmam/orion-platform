# Copy to caddy.env and set your domain.
# VPS (real HTTPS):     SITE_DOMAIN=orionilam.com
# Local test (no cert): SITE_DOMAIN=http://localhost
SITE_DOMAIN=orionilam.com

# www redirect (VPS only). Needs a DNS A record for "www" -> the same server IP.
# Locally: leave commented out.
WWW_DOMAIN=www.orionilam.com
